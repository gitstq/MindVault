{
  "name": "mindvault",
  "version": "1.0.0",
  "description": "A lightweight desktop app for managing markdown knowledge bases",
  "main": "dist/main.js",
  "author": "MindVault Team",
  "license": "MIT",
  "scripts": {
    "dev": "concurrently \"npm run dev:vite\" \"npm run dev:electron\"",
    "dev:vite": "cd renderer && vite",
    "dev:electron": "wait-on http://localhost:5173 && electron .",
    "build": "cd renderer && vite build && cd .. && electron-builder",
    "build:win": "cd renderer && vite build && cd .. && electron-builder --win",
    "build:mac": "cd renderer && vite build && cd .. && electron-builder --mac",
    "build:linux": "cd renderer && vite build && cd .. && electron-builder --linux",
    "lint": "eslint . --ext .ts,.tsx",
    "test": "echo \"Tests not yet implemented\""
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.17",
    "@types/node": "^22.15.21",
    "@vitejs/plugin-react": "^4.4.1",
    "concurrently": "^9.1.2",
    "electron": "^36.2.0",
    "electron-builder": "^26.0.12",
    "tailwindcss": "^4.1.17",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.3",
    "vite": "^6.3.5",
    "wait-on": "^8.0.3"
  },
  "dependencies": {
    "@uiw/react-md-editor": "^4.0.5",
    "fuse.js": "^7.1.0",
    "lucide-react": "^0.511.0",
    "rehype-sanitize": "^6.0.0",
    "zustand": "^5.0.12"
  },
  "build": {
    "appId": "com.mindvault.app",
    "productName": "MindVault",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "renderer/dist/**/*"
    ],
    "mac": {
      "target": "dmg",
      "category": "public.app-category.productivity"
    },
    "win": {
      "target": "nsis"
    },
    "linux": {
      "target": "AppImage",
      "category": "Office"
    }
  }
}
